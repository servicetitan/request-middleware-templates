{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "invoices.response",
  "type": "object",
  "description": "Response containing invoices fetched from a supplier",
  "additionalProperties": false,
  "properties": {
    "errorCode": {
      "type": [
        "null",
        "string"
      ],
      "description": "Error code returned from the vendor's API, if any"
    },
    "callBackInfo": {
      "description": "Optional callback information to be used in the next request. Only present if a callback is needed",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/definitions/CallbackInfo"
        }
      ]
    },
    "success": {
      "type": "boolean"
    },
    "errorKind": {
      "type": [
        "null",
        "string"
      ]
    },
    "message": {
      "type": [
        "null",
        "string"
      ]
    },
    "errorMessage": {
      "type": [
        "null",
        "string"
      ]
    },
    "invoices": {
      "type": "array",
      "description": "List of invoices returned by the supplier",
      "items": {
        "$ref": "#/definitions/InvoiceDto"
      }
    },
    "$schema": {
      "type": "string",
      "default": "./invoices.response.schema.json"
    }
  },
  "definitions": {
    "CallbackInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "shouldCallback": {
          "type": "boolean",
          "description": "Controls whether another request should be made"
        },
        "values": {
          "type": [
            "null",
            "object"
          ],
          "description": "Generic object to be passed to the next request\nUsed for passing data between chained requests",
          "additionalProperties": {}
        },
        "maxCallbacksForRequest": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        }
      }
    },
    "InvoiceDto": {
      "type": "object",
      "description": "Represents a single invoice from a supplier",
      "additionalProperties": false,
      "properties": {
        "invoiceNumber": {
          "type": "string",
          "description": "Unique invoice number from the supplier"
        },
        "invoiceDate": {
          "type": "string",
          "description": "Date of the invoice"
        },
        "lineItems": {
          "type": "array",
          "description": "Line items on this invoice",
          "items": {
            "$ref": "#/definitions/InvoiceLineItemDto"
          }
        }
      }
    },
    "InvoiceLineItemDto": {
      "type": "object",
      "description": "Represents a line item on a supplier invoice",
      "additionalProperties": false,
      "properties": {
        "itemId": {
          "type": "string",
          "description": "Product/item identifier from the supplier"
        },
        "quantity": {
          "type": "integer",
          "description": "Quantity on the invoice line",
          "format": "int32"
        },
        "price": {
          "type": "number",
          "description": "Unit price for the item",
          "format": "decimal"
        },
        "total": {
          "type": "number",
          "description": "Total amount for this line item",
          "format": "decimal"
        }
      }
    }
  }
}